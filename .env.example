# Slack Configuration
# Create a Slack app at https://api.slack.com/apps
# Bot Token Scopes: channels:history, channels:read, chat:write, groups:history, groups:read, im:history, im:read, mpim:history, mpim:read, users:read
SLACK_BOT_TOKEN=xoxb-your-bot-token
# User Token Scopes: search:read (required for slack_search_messages)
SLACK_USER_TOKEN=xoxp-your-user-token

# Jira Configuration
# Create an API token at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_HOST=https://jfrog-int.atlassian.net
JIRA_EMAIL=your-email@jfrog.com
JIRA_API_TOKEN=your-api-token

# GitHub Enterprise Configuration
# Generate a PAT at https://github.jfrog.info/settings/tokens with repo scope
GITHUB_ENTERPRISE_URL=https://github.jfrog.info
GITHUB_ENTERPRISE_TOKEN=your-github-token
ARTIFACTORY_REPO=JFROG/artifactory-service
ARTIFACTORY_MFE_REPO=JFROG/artifactory-mfe

# Google Workspace Configuration
# 1. Go to https://console.cloud.google.com
# 2. Create/select a project, enable: Docs API, Sheets API, Slides API, Drive API, Calendar API
# 3. Create OAuth 2.0 credentials (Desktop app type)
# 4. Run: node dist/google-auth.js --client-id YOUR_ID --client-secret YOUR_SECRET
# 5. Follow the prompts to get your refresh token
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
